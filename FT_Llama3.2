import torch
import json
import os
from datasets import Dataset
from peft import get_peft_model, LoraConfig, prepare_model_for_kbit_training
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig
from trl import SFTConfig, SFTTrainer

DATASET_PATH = "/dataset/training_data_gemini.jsonl"
OUTPUT_DIR   = "/out/llama3-skincancer"
MODEL_ID     = "meta-llama/Llama-3.2-3B-Instruct"

os.makedirs(OUTPUT_DIR, exist_ok=True)

print("Load Data")
raw_data = []
with open(DATASET_PATH, "r") as f:
    for line in f:
        raw_data.append(json.loads(line))

def convert_to_messages(example):
    return {
        "messages": [
            {"role": "system",    "content": example["instruction"]},
            {"role": "user",      "content": example["input"]},
            {"role": "assistant", "content": example["output"]}
        ]
    }

dataset = Dataset.from_list([convert_to_messages(x) for x in raw_data])
print(f"Dataset: {len(dataset)} exemple")

bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type="nf4",
    bnb_4bit_use_double_quant=True,
    bnb_4bit_compute_dtype=torch.bfloat16
)

print("Loading Llama 3.2 3B")
model = AutoModelForCausalLM.from_pretrained(
    MODEL_ID,
    device_map="cuda:0",
    quantization_config=bnb_config,
)
print("Model loaded")

tokenizer = AutoTokenizer.from_pretrained(MODEL_ID)
tokenizer.pad_token = tokenizer.eos_token
tokenizer.pad_token_id = tokenizer.eos_token_id
print("Tokenizer loaded")

model = prepare_model_for_kbit_training(model)
lora_config = LoraConfig(
    r=16,
    lora_alpha=32,
    lora_dropout=0.05,
    task_type="CAUSAL_LM",
    target_modules=["q_proj", "k_proj", "v_proj", "o_proj",
                    "gate_proj", "up_proj", "down_proj"],
)
model = get_peft_model(model, lora_config)
model.print_trainable_parameters()

sft_config = SFTConfig(
    per_device_train_batch_size=4,
    auto_find_batch_size=True,
    gradient_checkpointing=True,
    gradient_checkpointing_kwargs={"use_reentrant": False},
    max_length=512,
    packing=True,
    num_train_epochs=5,
    learning_rate=2e-4,
    optim="paged_adamw_8bit",
    logging_steps=10,
    save_steps=200,
    output_dir=OUTPUT_DIR,
    report_to="none",
    bf16=True,
)

trainer = SFTTrainer(
    model=model.base_model.model,
    peft_config=lora_config,
    processing_class=tokenizer,
    args=sft_config,
    train_dataset=dataset,
)

print("Antrenarea a inceput")
trainer.train()
print("Antrenare finalizata")

trainer.save_model(OUTPUT_DIR)
tokenizer.save_pretrained(OUTPUT_DIR)
print(f"Adapter salvat in: {OUTPUT_DIR}")


